#!/bin/bash

# DigWis 面板管理工具
# 提供安装、卸载、状态查看等功能

set -e

# 版本信息
VERSION="0.1.0-alpha"
SCRIPT_NAME="digwis"

# 路径配置
INSTALL_DIR="/opt/digwis-panel"
CONFIG_DIR="/etc/digwis-panel"
LOG_DIR="/var/log/digwis-panel"
SERVICE_NAME="digwis-panel"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 打印函数
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_header() {
    echo -e "${CYAN}$1${NC}"
}

# 显示Logo和版本信息
show_logo() {
    clear
    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════╗"
    echo "║           DigWis 面板管理工具         ║"
    echo "║              v${VERSION}              ║"
    echo "╚══════════════════════════════════════╝"
    echo -e "${NC}"
}

# 检查是否已安装
check_installation() {
    if [ -f "$INSTALL_DIR/digwis-panel" ] && [ -f "/etc/systemd/system/$SERVICE_NAME.service" ]; then
        return 0
    else
        return 1
    fi
}

# 获取服务状态
get_service_status() {
    if systemctl is-active --quiet $SERVICE_NAME 2>/dev/null; then
        echo "running"
    elif systemctl is-enabled --quiet $SERVICE_NAME 2>/dev/null; then
        echo "stopped"
    else
        echo "not_installed"
    fi
}

# 显示状态信息
show_status() {
    print_header "📊 系统状态"
    echo ""
    
    if check_installation; then
        print_success "DigWis 面板已安装"
        echo "   📁 安装目录: $INSTALL_DIR"
        echo "   📁 配置目录: $CONFIG_DIR"
        echo "   📁 日志目录: $LOG_DIR"
        echo ""
        
        local status=$(get_service_status)
        case $status in
            "running")
                print_success "服务状态: 运行中"
                echo "   🌐 访问地址: http://localhost:8080"
                ;;
            "stopped")
                print_warning "服务状态: 已停止"
                ;;
            "not_installed")
                print_error "服务状态: 未安装"
                ;;
        esac
        
        # 显示资源使用情况
        if systemctl is-active --quiet $SERVICE_NAME 2>/dev/null; then
            echo ""
            print_info "资源使用情况:"
            systemctl status $SERVICE_NAME --no-pager -l | grep -E "(Memory|CPU|Tasks)" | sed 's/^/   /'
        fi
    else
        print_warning "DigWis 面板未安装"
    fi
    echo ""
}

# 安装面板
install_panel() {
    print_header "🚀 安装 DigWis 面板"
    echo ""
    
    if check_installation; then
        print_warning "DigWis 面板已经安装，如需重新安装请先卸载"
        return 1
    fi
    
    print_info "开始下载并执行安装脚本..."
    echo ""
    
    # 下载并执行安装脚本
    if curl -sSL https://raw.githubusercontent.com/digwis/digwis-panel/main/install.sh | sudo bash; then
        echo ""
        print_success "安装完成！"
        print_info "访问地址: http://localhost:8080"
    else
        print_error "安装失败，请检查网络连接或查看错误信息"
        return 1
    fi
}

# 卸载面板
uninstall_panel() {
    print_header "🗑️  卸载 DigWis 面板"
    echo ""
    
    if ! check_installation; then
        print_warning "DigWis 面板未安装"
        return 1
    fi
    
    echo -e "${YELLOW}警告: 此操作将完全删除 DigWis 面板及其所有数据！${NC}"
    echo -n "确认卸载? (y/N): "
    read -r confirm
    
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        print_info "取消卸载"
        return 0
    fi
    
    print_info "开始卸载..."
    
    # 停止并禁用服务
    sudo systemctl stop $SERVICE_NAME 2>/dev/null || true
    sudo systemctl disable $SERVICE_NAME 2>/dev/null || true
    
    # 删除服务文件
    sudo rm -f /etc/systemd/system/$SERVICE_NAME.service
    
    # 重新加载systemd配置
    sudo systemctl daemon-reload
    sudo systemctl reset-failed
    
    # 删除程序文件
    sudo rm -rf $INSTALL_DIR
    
    # 删除配置文件
    sudo rm -rf $CONFIG_DIR
    
    # 删除日志文件
    sudo rm -rf $LOG_DIR
    
    # 删除临时文件
    sudo rm -rf /tmp/digwis-panel-install
    sudo rm -rf /tmp/digwis-install
    
    # 清理防火墙规则
    sudo ufw delete allow 8080/tcp 2>/dev/null || true
    sudo firewall-cmd --permanent --remove-port=8080/tcp 2>/dev/null || true
    sudo firewall-cmd --reload 2>/dev/null || true
    
    print_success "卸载完成！"
}

# 启动服务
start_service() {
    if ! check_installation; then
        print_error "DigWis 面板未安装"
        return 1
    fi
    
    print_info "启动 DigWis 面板服务..."
    if sudo systemctl start $SERVICE_NAME; then
        print_success "服务启动成功"
        print_info "访问地址: http://localhost:8080"
    else
        print_error "服务启动失败"
        return 1
    fi
}

# 停止服务
stop_service() {
    if ! check_installation; then
        print_error "DigWis 面板未安装"
        return 1
    fi
    
    print_info "停止 DigWis 面板服务..."
    if sudo systemctl stop $SERVICE_NAME; then
        print_success "服务停止成功"
    else
        print_error "服务停止失败"
        return 1
    fi
}

# 重启服务
restart_service() {
    if ! check_installation; then
        print_error "DigWis 面板未安装"
        return 1
    fi
    
    print_info "重启 DigWis 面板服务..."
    if sudo systemctl restart $SERVICE_NAME; then
        print_success "服务重启成功"
        print_info "访问地址: http://localhost:8080"
    else
        print_error "服务重启失败"
        return 1
    fi
}

# 查看日志
show_logs() {
    if ! check_installation; then
        print_error "DigWis 面板未安装"
        return 1
    fi
    
    print_header "📋 查看日志"
    echo ""
    print_info "按 Ctrl+C 退出日志查看"
    echo ""
    
    sudo journalctl -u $SERVICE_NAME -f --no-pager
}

# 显示主菜单
show_menu() {
    show_logo
    show_status
    
    echo -e "${CYAN}请选择操作:${NC}"
    echo ""
    echo "  1) 📊 查看状态"
    echo "  2) 🚀 安装面板"
    echo "  3) 🗑️  卸载面板"
    echo "  4) ▶️  启动服务"
    echo "  5) ⏹️  停止服务"
    echo "  6) 🔄 重启服务"
    echo "  7) 📋 查看日志"
    echo "  8) ❓ 帮助信息"
    echo "  0) 🚪 退出"
    echo ""
    echo -n "请输入选项 [0-8]: "
}

# 显示帮助信息
show_help() {
    print_header "❓ 帮助信息"
    echo ""
    echo "DigWis 面板管理工具 v$VERSION"
    echo ""
    echo "用法:"
    echo "  $SCRIPT_NAME [选项]"
    echo ""
    echo "选项:"
    echo "  status      查看面板状态"
    echo "  install     安装面板"
    echo "  uninstall   卸载面板"
    echo "  start       启动服务"
    echo "  stop        停止服务"
    echo "  restart     重启服务"
    echo "  logs        查看日志"
    echo "  help        显示帮助信息"
    echo "  version     显示版本信息"
    echo ""
    echo "如果不提供参数，将显示交互式菜单。"
    echo ""
    echo "更多信息请访问: https://github.com/digwis/digwis-panel"
    echo ""
}

# 显示版本信息
show_version() {
    echo "DigWis 面板管理工具 v$VERSION"
}

# 主函数
main() {
    case "${1:-}" in
        "status")
            show_logo
            show_status
            ;;
        "install")
            show_logo
            install_panel
            ;;
        "uninstall")
            show_logo
            uninstall_panel
            ;;
        "start")
            start_service
            ;;
        "stop")
            stop_service
            ;;
        "restart")
            restart_service
            ;;
        "logs")
            show_logs
            ;;
        "help"|"-h"|"--help")
            show_help
            ;;
        "version"|"-v"|"--version")
            show_version
            ;;
        "")
            # 交互式菜单
            while true; do
                show_menu
                read -r choice
                echo ""
                
                case $choice in
                    1)
                        show_logo
                        show_status
                        echo ""
                        echo -n "按回车键继续..."
                        read -r
                        ;;
                    2)
                        install_panel
                        echo ""
                        echo -n "按回车键继续..."
                        read -r
                        ;;
                    3)
                        uninstall_panel
                        echo ""
                        echo -n "按回车键继续..."
                        read -r
                        ;;
                    4)
                        start_service
                        echo ""
                        echo -n "按回车键继续..."
                        read -r
                        ;;
                    5)
                        stop_service
                        echo ""
                        echo -n "按回车键继续..."
                        read -r
                        ;;
                    6)
                        restart_service
                        echo ""
                        echo -n "按回车键继续..."
                        read -r
                        ;;
                    7)
                        show_logs
                        ;;
                    8)
                        show_help
                        echo ""
                        echo -n "按回车键继续..."
                        read -r
                        ;;
                    0)
                        print_info "再见！"
                        exit 0
                        ;;
                    *)
                        print_error "无效选项，请重新选择"
                        sleep 2
                        ;;
                esac
            done
            ;;
        *)
            print_error "未知参数: $1"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

# 执行主函数
main "$@"
