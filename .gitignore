# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Log files
*.log

# Config files with sensitive data
config.yaml
config.yml
*.env

# Build artifacts
digwis-panel
server-panel

# Release directory (keep structure but ignore binaries)
release/*.tar.gz
release/*.exe
release/digwis-panel-*

# Temporary files
tmp/
temp/
*.tmp

# Backup files
*.bak
*.backup
